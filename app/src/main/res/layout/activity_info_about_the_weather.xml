<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".InfoAboutTheWeather">

    <ImageView
        android:id="@+id/weatherBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Основной контент -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/city_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:hint="City name"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/time"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:hint="Time"
                android:textSize="40dp" />

            <ImageButton
                android:id="@+id/imageButtonClose"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="5dp"
                android:padding="10dp"
                app:srcCompat="@android:drawable/ic_menu_close_clear_cancel" />

        </LinearLayout>

        <TextView
            android:id="@+id/the_temperature_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="0°"
            android:padding="10dp"
            android:textSize="90dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:columnCount="2"
            android:rowCount="4">

            <TextView
                android:id="@+id/pressure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:background="@drawable/text_bg"
                android:hint="humidity: "
                android:padding="15dp"
                android:textSize="17dp" />

            <TextView
                android:id="@+id/humidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:background="@drawable/text_bg"
                android:hint="humidity: "
                android:padding="15dp"
                android:textSize="17dp" />

            <TextView
                android:id="@+id/wind_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:background="@drawable/text_bg"
                android:hint="humidity: "
                android:padding="15dp"
                android:textSize="17dp" />

            <TextView
                android:id="@+id/weathercode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:background="@drawable/text_bg"
                android:hint="humidity: "
                android:padding="15dp"
                android:textSize="17dp" />

        </GridLayout>

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"
            android:layout_width="match_parent"
            android:layout_height="350dp" />

    </LinearLayout>

    <!-- Дождь поверх контента -->
    <com.example.weathertracking.RainView
        android:id="@+id/rainView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>